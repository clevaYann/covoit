{
  "info": {
    "name": "Covoit API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Tests automatiques de l API Covoit"
  },
  "item": [
    {
      "name": "GET /api/employes",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /api/employes",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nom\": \"Postman\",\n  \"prenom\": \"Runner\",\n  \"email\": \"postman.runner+{{$timestamp}}@mail.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Has data.id', function () {",
              "  pm.expect(body).to.have.property('data');",
              "  pm.expect(body.data).to.have.property('id');",
              "});",
              "pm.collectionVariables.set('employeId', body.data.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/employes/{id} blocked by middleware",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employes/{{employeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employes",
            "{{employeId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 403 expected', function () {",
              "  pm.response.to.have.status(403);",
              "});",
              "pm.test('Contains message', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('message');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH /api/employes/{id}",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"prenom\": \"RunnerPatch\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employes/{{employeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employes",
            "{{employeId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Prenom updated', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.prenom).to.eql('RunnerPatch');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /api/vehicules",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/vehicules",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "vehicules"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is array', function () {",
              "  const data = pm.response.json();",
              "  pm.expect(Array.isArray(data)).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "DELETE /api/employes/{id}",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employes/{{employeId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "employes",
            "{{employeId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 204', function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:8092"
    },
    {
      "key": "employeId",
      "value": ""
    }
  ]
}
